{
  "name": "honglou-sims",
  "version": "1.0.0",
  "private": true,
  "description": "HonglouSims — 本地/局域网/远程可访问的静态游戏服务",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node serve.mjs",
    "start:local": "BIND_LOCAL=1 node serve.mjs",
    "test:config": "node tests/config/validate-config.mjs",
    "test:smoke": "node tests/smoke/smoke-ui.mjs",
    "test:admin": "node tests/smoke/smoke-admin.mjs",
    "test:command": "node tests/smoke/smoke-command-panel.mjs",
    "test:scenario": "node tests/scenarios/run-all.mjs",
    "test:release": "npm run test:config && npm run test:smoke && npm run test:admin && npm run test:command && npm run test:scenario",
    "test:economy": "node scripts/test-economy.mjs",
    "test:needs": "node scripts/test-need-adaptation.mjs",
    "test:need-states": "node scripts/test-need-states.mjs",
    "portraits": "python3 scripts/process_portraits.py",
    "tunnel": "cloudflared tunnel --url http://127.0.0.1:${PORT:-8765}",
    "docker:build": "docker build -t dayuan-game .",
    "docker:run": "docker run --rm -p 8765:8765 dayuan-game"
  }
}
